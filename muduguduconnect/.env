# ── DATABASE ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=muduguduconnect
DB_USER=root
DB_PASS=

# ── SERVER ──
PORT=3001
NODE_ENV=development

# ── JWT ──
JWT_SECRET=mudugudu_super_secret_key_change_in_prod
JWT_EXPIRES=7d

# ── EMAIL (Nodemailer) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=MuduguduConnect <no-reply@muduguduconnect.rw>

# ── UPLOAD ──
UPLOAD_DIR=public/assets/uploads
MAX_FILE_SIZE=5242880
